# ============================================
# HERMES MISSION CONTROL — Environment Setup
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Fathom AI — https://fathom.video/settings/api
VITE_FATHOM_API_KEY=your_fathom_api_key

# Resend — https://resend.com/api-keys
VITE_RESEND_API_KEY=your_resend_api_key

# Apify — https://console.apify.com/account/integrations
VITE_APIFY_API_KEY=your_apify_api_key

# Hermes API Key (generate with: openssl rand -hex 32)
# Set this same key as a Supabase secret: supabase secrets set HERMES_API_KEY=<key>
VITE_HERMES_API_KEY=your_hermes_api_key

# ============================================
# Supabase Secrets (set via CLI, not in this file)
# ============================================
# supabase secrets set HERMES_API_KEY=<your_hermes_api_key>
# supabase secrets set FATHOM_API_KEY=<your_fathom_api_key>
# supabase secrets set RESEND_API_KEY=<your_resend_api_key>
# supabase secrets set APIFY_API_KEY=<your_apify_api_key>
# supabase secrets set DEFAULT_FROM_NAME="Your Name"
# supabase secrets set DEFAULT_FROM_EMAIL="you@yourdomain.com"
# supabase secrets set DEFAULT_REPLY_TO="you@yourdomain.com"
